# ═══════════════════════════════════════════════════════════════
# Aurora Theme — Color Variables
# Premium modern dark theme with cyan/violet accents
# ═══════════════════════════════════════════════════════════════

# ── Core Brand Colors ─────────────────────────────────────────
color.primary=#58A6FF
color.primary.dim=#388BFD
color.primary.bright=#79C0FF
color.secondary=#BC8CFF
color.secondary.dim=#A371F7
color.accent=#7EE787
color.accent.dim=#56D364
color.cyan=#76E4F7
color.cyan.dim=#39D2E6

# ── Semantic Colors ───────────────────────────────────────────
color.success=#7EE787
color.warning=#E3B341
color.error=#FF7B72
color.info=#58A6FF
color.yellow_dark=#E3B341

# ── Surface Colors ────────────────────────────────────────────
color.surface.darkest=#0D1117
color.surface.dark=#161B22
color.surface.medium=#21262D
color.surface.light=#30363D
color.surface.lighter=#484F58
color.surface.hover=#1F2937

# ── Font Colors ───────────────────────────────────────────────
font.color=#C9D1D9
font.color.muted=#8B949E
font.color.bright=#F0F6FC
disabled.color=#484F58

# ── Widget Backgrounds ───────────────────────────────────────
outer_widget.background.color=@color.surface.dark
inner_widget.background.color=@color.surface.darkest

# ── Push Buttons ──────────────────────────────────────────────
pushbutton.background.color=@color.surface.medium
pushbutton.border.color=@color.surface.light
pushbutton.disabled.background.color=@color.surface.dark
pushbutton.disabled.font.color=@disabled.color

# ── Button OK / Primary ──────────────────────────────────────
button_ok.background.color=#238636
button_ok.font.color=#FFFFFF

# ── Inputs ────────────────────────────────────────────────────
lineedit.background.color=@color.surface.darkest
lineedit.border.color=@color.surface.light
focus.border.color=@color.primary
combobox.border.color=@color.surface.light

# ── Scroll Bar ────────────────────────────────────────────────
scrollbar.handle.background.color=@color.surface.lighter

# ── Menu ──────────────────────────────────────────────────────
menu.item.selected.background.color=@color.primary.dim
menu.item.selected.font.color=#FFFFFF

# ── Tabs ──────────────────────────────────────────────────────
tab.font.color=@color.primary
tab.highlight.color=@color.surface.medium
tab.underline.color=@color.primary

# ── Table ─────────────────────────────────────────────────────
table.border.color=@color.surface.light
table.selection.background.color=#1A2332
table.button.hover.background.color=@color.surface.medium
table.app_publisher.unknown.font.color=@color.error
table.app_version.update.color=@color.warning
table.app_version.update.weight=bold
table.app_version.update_ignored.color=@font.color.muted
table.update_check.disabled.color=@color.warning
table.bt_install.font.color=@color.accent
table.bt_uninstall.font.color=@color.error

# ── Progress Bar ──────────────────────────────────────────────
progressbar.fill.color=@color.primary

# ── Console ───────────────────────────────────────────────────
console.background.color=@color.surface.darkest
console.font.color=#B5BDC5

# ── History ───────────────────────────────────────────────────
history.version.focus.color=#FFFFFF
history.version.outdated=@color.warning
history.version.updated=@color.accent

# ── Upgrade ───────────────────────────────────────────────────
upgrade.color=@color.accent

# ── Task Status ───────────────────────────────────────────────
task.done.color=@color.accent.dim

# ── Tool Button ───────────────────────────────────────────────
toolbutton.hover.background.color=@color.surface.medium

# ── Errors ────────────────────────────────────────────────────
error.color=@color.error
color.warning=@color.yellow_dark
